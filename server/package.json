{
  "name": "projectagilite-server",
  "version": "1.0.0",
  "description": "Customer support ticketing API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "npm run seed:agent",
    "seed:agent": "ts-node-dev --transpile-only src/scripts/seed-agent.ts",
    "seed:products": "ts-node-dev --transpile-only src/scripts/seed-products.ts",
    "seed:product-images": "ts-node-dev --transpile-only src/scripts/seed-product-images.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@pydantic/logfire-node": "^0.13.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
