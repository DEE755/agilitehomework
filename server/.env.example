PORT=5050
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=MyApp
JWT_SECRET=change_me_to_a_long_random_string

# Cloudflare R2 (S3-compatible object storage)
S3_ENDPOINT=https://<accountId>.r2.cloudflarestorage.com/<bucket>
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional: set to your R2 public bucket URL to serve images without signed URLs
# e.g. https://pub-<hash>.r2.dev   or   https://assets.yourdomain.com
S3_PUBLIC_BASE_URL=

# Pydantic AI Gateway — LLM proxy used by the backend AI features
# All AI calls are made server-side only; keys are never exposed to the browser.
PYDANTIC_GATEWAY_BASE_URL=http://localhost:4000
PYDANTIC_GATEWAY_API_KEY=
PYDANTIC_GATEWAY_MODEL=gpt-4o-mini
